#!/bin/bash
#
# swingcam — CLI for managing the swing-cam server daemon on macOS.
#
# Usage:
#   swingcam start        Start the server daemon
#   swingcam stop         Stop the server daemon
#   swingcam restart      Restart the server daemon
#   swingcam status       Show daemon status and recent logs
#   swingcam logs         Tail the server logs
#   swingcam update [SHA] Pull latest main (or a specific SHA) and restart
#   swingcam config       Open the config file in $EDITOR
#   swingcam proxy        Set up Caddy reverse proxy (port 80 → server)
#

set -euo pipefail

# ── Paths ──
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVER_DIR="$REPO_DIR/server"
VENV_DIR="$SERVER_DIR/venv"

APP_DIR="$HOME/.swingcam"
CONFIG_FILE="$APP_DIR/config.yaml"
LOG_DIR="$APP_DIR/logs"
LOG_FILE="$LOG_DIR/swingcam.log"
ERR_FILE="$LOG_DIR/swingcam.err"

PLIST_NAME="com.swingcam.server"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"

PROXY_PLIST_NAME="com.swingcam.proxy"
PROXY_PLIST_DST="$HOME/Library/LaunchAgents/$PROXY_PLIST_NAME.plist"

# ── Helpers ──

_green()  { printf "\033[32m%s\033[0m\n" "$1"; }
_red()    { printf "\033[31m%s\033[0m\n" "$1"; }
_yellow() { printf "\033[33m%s\033[0m\n" "$1"; }

_get_web_port() {
    # Read web_port from config, default to 9555
    if [ -f "$CONFIG_FILE" ] && command -v python3 &>/dev/null; then
        python3 -c "
import yaml, sys
try:
    cfg = yaml.safe_load(open('$CONFIG_FILE'))
    print(cfg.get('server',{}).get('web_port', 9555))
except: print(9555)
" 2>/dev/null
    else
        echo "9555"
    fi
}

_ensure_app_dir() {
    if [ ! -d "$APP_DIR" ]; then
        echo "Creating $APP_DIR..."
        mkdir -p "$APP_DIR/clips" "$APP_DIR/logs" "$APP_DIR/models"
    fi

    # Copy default config if none exists
    if [ ! -f "$CONFIG_FILE" ]; then
        cp "$SERVER_DIR/config.default.yaml" "$CONFIG_FILE"
        echo "Created config at $CONFIG_FILE"
        echo "Edit it with: swingcam config"
    fi
}

_ensure_plist() {
    # Generate the plist dynamically so paths are always correct
    cat > "$PLIST_DST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$PLIST_NAME</string>

    <key>ProgramArguments</key>
    <array>
        <string>$VENV_DIR/bin/python</string>
        <string>$SERVER_DIR/main.py</string>
        <string>--config</string>
        <string>$CONFIG_FILE</string>
    </array>

    <key>WorkingDirectory</key>
    <string>$SERVER_DIR</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/dev/null</string>

    <key>StandardErrorPath</key>
    <string>$ERR_FILE</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
PLIST
}

_ensure_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        echo "Creating Python virtual environment..."
        python3 -m venv "$VENV_DIR"
        "$VENV_DIR/bin/pip" install --quiet --upgrade pip
        "$VENV_DIR/bin/pip" install --quiet -r "$SERVER_DIR/requirements.txt"
        _green "Virtual environment created."
    fi
}

_is_running() {
    launchctl list "$PLIST_NAME" &>/dev/null
}

_pid() {
    launchctl list "$PLIST_NAME" 2>/dev/null | head -1 | awk '{print $1}'
}

_is_proxy_running() {
    launchctl list "$PROXY_PLIST_NAME" &>/dev/null
}

# ── Commands ──

cmd_start() {
    _ensure_app_dir
    _ensure_venv
    _ensure_plist

    if _is_running; then
        local pid
        pid=$(_pid)
        if [ "$pid" != "-" ] && [ -n "$pid" ]; then
            _yellow "swing-cam is already running (PID $pid)"
            return 0
        fi
    fi

    launchctl load "$PLIST_DST"
    sleep 1

    local port
    port=$(_get_web_port)

    if _is_running; then
        local pid
        pid=$(_pid)
        _green "swing-cam started (PID $pid)"
        echo "  Web UI:  http://localhost:$port"
        if _is_proxy_running; then
            echo "  Proxy:   http://home-server.local (port 80 → $port)"
        fi
        echo "  Config:  $CONFIG_FILE"
        echo "  Clips:   $APP_DIR/clips"
        echo "  Logs:    $LOG_FILE"
    else
        _red "Failed to start. Check logs:"
        echo "  $ERR_FILE"
        return 1
    fi
}

cmd_stop() {
    if ! _is_running; then
        _yellow "swing-cam is not running."
        return 0
    fi

    launchctl unload "$PLIST_DST"
    sleep 1
    _green "swing-cam stopped."
}

cmd_restart() {
    echo "Restarting swing-cam..."
    cmd_stop
    cmd_start
}

cmd_status() {
    local port
    port=$(_get_web_port)

    echo "── swing-cam status ──"
    if _is_running; then
        local pid
        pid=$(_pid)
        if [ "$pid" != "-" ] && [ -n "$pid" ]; then
            _green "Running (PID $pid) on port $port"
        else
            _yellow "Loaded but not running (may be restarting)"
        fi
    else
        _red "Not running"
    fi

    if _is_proxy_running; then
        _green "Proxy: port 80 → $port"
    fi

    echo ""
    echo "── Paths ──"
    echo "Config:  $CONFIG_FILE"
    echo "Clips:   $APP_DIR/clips"
    echo "DB:      $APP_DIR/swings.db"
    echo "Logs:    $LOG_DIR"

    echo ""
    echo "── Git ──"
    (cd "$REPO_DIR" && echo "Branch: $(git branch --show-current)" && echo "Commit: $(git log --oneline -1)")

    echo ""
    echo "── Storage ──"
    if [ -d "$APP_DIR/clips" ]; then
        local clips_size clips_count
        clips_size=$(du -sh "$APP_DIR/clips" 2>/dev/null | awk '{print $1}')
        clips_count=$(find "$APP_DIR/clips" -name "*.mp4" 2>/dev/null | wc -l | tr -d ' ')
        echo "Clips: $clips_size ($clips_count files)"
    fi
    if [ -d "$LOG_DIR" ]; then
        local log_size
        log_size=$(du -sh "$LOG_DIR" 2>/dev/null | awk '{print $1}')
        echo "Logs:  $log_size (rotates at 10MB, keeps 5 backups)"
    fi

    echo ""
    echo "── Recent logs ──"
    tail -10 "$LOG_FILE" 2>/dev/null || echo "(no log file yet)"
}

cmd_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "No log file yet. Start the server first."
        return 1
    fi
    tail -f "$LOG_FILE" "$ERR_FILE"
}

cmd_config() {
    _ensure_app_dir
    "${EDITOR:-vi}" "$CONFIG_FILE"
    if _is_running; then
        echo ""
        read -rp "Config changed. Restart server? [y/N] " answer
        if [[ "$answer" =~ ^[Yy] ]]; then
            cmd_restart
        fi
    fi
}

cmd_proxy() {
    local subcmd="${1:-setup}"

    case "$subcmd" in
        setup)
            # Check for caddy
            if ! command -v caddy &>/dev/null; then
                echo "Caddy not found. Installing via Homebrew..."
                brew install caddy
            fi

            local port
            port=$(_get_web_port)

            # Generate launchd plist for caddy
            cat > "$PROXY_PLIST_DST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$PROXY_PLIST_NAME</string>

    <key>ProgramArguments</key>
    <array>
        <string>$(which caddy)</string>
        <string>reverse-proxy</string>
        <string>--from</string>
        <string>:80</string>
        <string>--to</string>
        <string>:$port</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/dev/null</string>

    <key>StandardErrorPath</key>
    <string>$LOG_DIR/caddy.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
PLIST

            # Port 80 requires elevated privileges
            if _is_proxy_running; then
                launchctl unload "$PROXY_PLIST_DST" 2>/dev/null || true
                sleep 1
            fi

            echo "Starting Caddy reverse proxy (port 80 → $port)..."
            echo "Note: port 80 may require sudo. If it fails, run:"
            echo "  sudo caddy reverse-proxy --from :80 --to :$port"
            echo ""

            launchctl load "$PROXY_PLIST_DST"
            sleep 1

            if _is_proxy_running; then
                _green "Proxy running: http://home-server.local → localhost:$port"
            else
                _yellow "Proxy may have failed to bind port 80."
                echo "Try: sudo caddy reverse-proxy --from :80 --to :$port"
            fi
            ;;

        stop)
            if _is_proxy_running; then
                launchctl unload "$PROXY_PLIST_DST" 2>/dev/null || true
                sleep 1
                _green "Proxy stopped."
            else
                _yellow "Proxy is not running."
            fi
            ;;

        status)
            if _is_proxy_running; then
                local port
                port=$(_get_web_port)
                _green "Proxy running: port 80 → $port"
            else
                _red "Proxy not running"
            fi
            ;;

        *)
            echo "Usage: swingcam proxy [setup|stop|status]"
            ;;
    esac
}

cmd_update() {
    local target="${1:-main}"

    echo "── Updating swing-cam ──"

    # Fetch latest
    (cd "$REPO_DIR" && git fetch origin)

    if [ "$target" = "main" ]; then
        echo "Pulling latest main..."
        (cd "$REPO_DIR" && git checkout main && git pull origin main)
    else
        echo "Checking out $target..."
        (cd "$REPO_DIR" && git checkout "$target")
    fi

    local commit
    commit=$(cd "$REPO_DIR" && git log --oneline -1)
    echo "Now at: $commit"

    # Update dependencies
    echo "Updating dependencies..."
    "$VENV_DIR/bin/pip" install --quiet -r "$SERVER_DIR/requirements.txt"
    _green "Dependencies updated."

    # Regenerate plist in case paths changed
    _ensure_plist

    # Restart if running
    if _is_running; then
        echo "Restarting server..."
        cmd_restart
    else
        _yellow "Server not running. Start with: swingcam start"
    fi

    _green "Update complete."
}

cmd_help() {
    cat <<HELP
swingcam — manage the swing-cam server daemon

Commands:
  start           Start the server daemon
  stop            Stop the server daemon
  restart         Restart the server daemon
  status          Show daemon status, paths, storage, and recent logs
  logs            Tail the server logs (Ctrl+C to stop)
  config          Edit the config file (restarts server if running)
  update [SHA]    Pull latest main (or checkout a specific SHA) and restart
  proxy           Set up Caddy reverse proxy (port 80 → server)
  proxy stop      Stop the reverse proxy
  proxy status    Check if the proxy is running

Data directory: $APP_DIR
  config.yaml     Server configuration
  clips/          Saved swing clips
  swings.db       Swing database
  logs/           Rotated log files
  models/         MediaPipe model files (auto-downloaded)

First-time setup:
  swingcam start
  swingcam proxy           # optional: access via http://home-server.local
HELP
}

# ── Main ──

case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    config)  cmd_config ;;
    update)  cmd_update "${2:-main}" ;;
    proxy)   cmd_proxy "${2:-setup}" ;;
    help|--help|-h) cmd_help ;;
    *)
        _red "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
