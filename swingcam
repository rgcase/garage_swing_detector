#!/bin/bash
#
# swingcam — CLI for the swing-cam server daemon (macOS) and Pi streamer.
#
# Server commands (macOS):
#   swingcam start        Start the server daemon
#   swingcam stop         Stop the server daemon
#   swingcam restart      Restart the server daemon
#   swingcam status       Show daemon status and recent logs
#   swingcam logs         Tail the server logs
#   swingcam update [SHA] Pull latest main (or a specific SHA) and restart
#   swingcam config       Open the config file in $EDITOR
#
# Pi commands (Raspberry Pi):
#   swingcam stream <ff|dtl> [server_ip]
#                         Stream H.264 video to the server. The angle
#                         (front-facing or down-the-line) selects which
#                         server port to connect to.
#

set -euo pipefail

# ── Paths ──
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"
SERVER_DIR="$REPO_DIR/server"
VENV_DIR="$SERVER_DIR/venv"

APP_DIR="$HOME/.swingcam"
CONFIG_FILE="$APP_DIR/config.yaml"
LOG_DIR="$APP_DIR/logs"
LOG_FILE="$LOG_DIR/swingcam.log"
ERR_FILE="$LOG_DIR/swingcam.err"

PLIST_NAME="com.swingcam.server"
PLIST_DST="$HOME/Library/LaunchAgents/$PLIST_NAME.plist"

# Pi streamer service (Linux/systemd). swingcam stream start writes
# this unit file and enables it; swingcam stream stop disables it.
SYSTEMD_UNIT_NAME="swing-cam-stream.service"
SYSTEMD_UNIT_PATH="/etc/systemd/system/$SYSTEMD_UNIT_NAME"

# ── Helpers ──

_green()  { printf "\033[32m%s\033[0m\n" "$1"; }
_red()    { printf "\033[31m%s\033[0m\n" "$1"; }
_yellow() { printf "\033[33m%s\033[0m\n" "$1"; }

_get_web_port() {
    # Read web_port from config with grep (no Python dependency)
    if [ -f "$CONFIG_FILE" ]; then
        grep -A1 '^server:' "$CONFIG_FILE" 2>/dev/null \
            | grep 'web_port' \
            | awk '{print $2}' \
            | tr -d ' ' \
            || echo "9555"
    else
        echo "9555"
    fi
}

_print_stream_targets() {
    # Requires venv (Python + PyYAML). Caller must ensure venv exists.
    [ -x "$VENV_DIR/bin/python" ] || return 0
    [ -f "$CONFIG_FILE" ] || return 0
    "$VENV_DIR/bin/python" - "$CONFIG_FILE" <<'PY'
import socket, sys, yaml
with open(sys.argv[1]) as f:
    cfg = yaml.safe_load(f) or {}

s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
try:
    s.connect(("8.8.8.8", 80))
    lan_ip = s.getsockname()[0]
except OSError:
    lan_ip = "localhost"
finally:
    s.close()

for cam in cfg.get("cameras", []):
    host = cam.get("host", "0.0.0.0")
    if host in ("0.0.0.0", "::"):
        host = lan_ip
    name = cam.get("name", "?")
    angle = cam.get("angle", "")
    suffix = f" ({angle})" if angle and angle != name else ""
    print(f"  Stream:  {name}{suffix}  →  tcp://{host}:{cam['port']}")

audio = cfg.get("audio") or {}
if audio.get("enabled", True):
    host = audio.get("host", "0.0.0.0")
    if host in ("0.0.0.0", "::"):
        host = lan_ip
    port = audio.get("port", 9558)
    print(f"  Audio:   any Pi w/ USB mic  →  tcp://{host}:{port}")
PY
}

_ensure_app_dir() {
    if [ ! -d "$APP_DIR" ]; then
        echo "Creating $APP_DIR..."
        mkdir -p "$APP_DIR/clips" "$APP_DIR/logs" "$APP_DIR/models"
    fi

    # Copy default config if none exists
    if [ ! -f "$CONFIG_FILE" ]; then
        cp "$SERVER_DIR/config.default.yaml" "$CONFIG_FILE"
        echo "Created config at $CONFIG_FILE"
        echo "Edit it with: swingcam config"
    fi
}

_ensure_plist() {
    # Generate the plist dynamically so paths are always correct
    cat > "$PLIST_DST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$PLIST_NAME</string>

    <key>ProgramArguments</key>
    <array>
        <string>$VENV_DIR/bin/python</string>
        <string>$SERVER_DIR/main.py</string>
        <string>--config</string>
        <string>$CONFIG_FILE</string>
    </array>

    <key>WorkingDirectory</key>
    <string>$SERVER_DIR</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/dev/null</string>

    <key>StandardErrorPath</key>
    <string>$ERR_FILE</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
PLIST
}

_ensure_venv() {
    if [ ! -d "$VENV_DIR" ]; then
        echo "Creating Python virtual environment..."
        python3 -m venv "$VENV_DIR"
        "$VENV_DIR/bin/pip" install --quiet --upgrade pip
        "$VENV_DIR/bin/pip" install --quiet -r "$SERVER_DIR/requirements.txt"
        _green "Virtual environment created."
    fi
}

_is_running() {
    launchctl list "$PLIST_NAME" &>/dev/null
}

_pid() {
    # `launchctl list <label>` returns a dict like:  "PID" = 12345;
    # Extract just the number; empty if loaded-but-not-running.
    launchctl list "$PLIST_NAME" 2>/dev/null \
        | awk -F'"PID" = ' '/"PID"/ {sub(/;.*/, "", $2); print $2; exit}'
}

# ── Commands ──

cmd_start() {
    _ensure_app_dir
    _ensure_venv
    _ensure_plist

    if _is_running; then
        local pid
        pid=$(_pid)
        if [ "$pid" != "-" ] && [ -n "$pid" ]; then
            _yellow "swing-cam is already running (PID $pid)"
            return 0
        fi
    fi

    launchctl load "$PLIST_DST"
    sleep 1

    local port
    port=$(_get_web_port)

    if _is_running; then
        local pid
        pid=$(_pid)
        _green "swing-cam started (PID $pid)"
        echo "  Web UI:  http://localhost:$port"
        _print_stream_targets
        echo "  Config:  $CONFIG_FILE"
        echo "  Clips:   $APP_DIR/clips"
        echo "  Logs:    $LOG_FILE"
    else
        _red "Failed to start. Check logs:"
        echo "  $ERR_FILE"
        return 1
    fi
}

cmd_stop() {
    if ! _is_running; then
        _yellow "swing-cam is not running."
        return 0
    fi

    launchctl unload "$PLIST_DST"
    sleep 1
    _green "swing-cam stopped."
}

cmd_restart() {
    echo "Restarting swing-cam..."
    cmd_stop
    cmd_start
}

cmd_status() {
    local port
    port=$(_get_web_port)

    echo "── swing-cam status ──"
    if _is_running; then
        local pid
        pid=$(_pid)
        if [ "$pid" != "-" ] && [ -n "$pid" ]; then
            _green "Running (PID $pid) on port $port"
        else
            _yellow "Loaded but not running (may be restarting)"
        fi
    else
        _red "Not running"
    fi

    echo ""
    echo "── Paths ──"
    echo "Config:  $CONFIG_FILE"
    echo "Clips:   $APP_DIR/clips"
    echo "DB:      $APP_DIR/swings.db"
    echo "Logs:    $LOG_DIR"

    echo ""
    echo "── Git ──"
    (cd "$REPO_DIR" && echo "Branch: $(git branch --show-current)" && echo "Commit: $(git log --oneline -1)")

    echo ""
    echo "── Storage ──"
    if [ -d "$APP_DIR/clips" ]; then
        local clips_size clips_count
        clips_size=$(du -sh "$APP_DIR/clips" 2>/dev/null | awk '{print $1}')
        clips_count=$(find "$APP_DIR/clips" -name "*.mp4" 2>/dev/null | wc -l | tr -d ' ')
        echo "Clips: $clips_size ($clips_count files)"
    fi
    if [ -d "$LOG_DIR" ]; then
        local log_size
        log_size=$(du -sh "$LOG_DIR" 2>/dev/null | awk '{print $1}')
        echo "Logs:  $log_size (rotates at 10MB, keeps 5 backups)"
    fi

    echo ""
    echo "── Recent logs ──"
    tail -10 "$LOG_FILE" 2>/dev/null || echo "(no log file yet)"
}

cmd_logs() {
    if [ ! -f "$LOG_FILE" ]; then
        echo "No log file yet. Start the server first."
        return 1
    fi
    tail -f "$LOG_FILE" "$ERR_FILE"
}

cmd_config() {
    _ensure_app_dir
    "${EDITOR:-vi}" "$CONFIG_FILE"
    if _is_running; then
        echo ""
        read -rp "Config changed. Restart server? [y/N] " answer
        if [[ "$answer" =~ ^[Yy] ]]; then
            cmd_restart
        fi
    fi
}

cmd_update() {
    local target="${1:-main}"

    echo "── Updating swing-cam ──"

    # Fetch latest
    (cd "$REPO_DIR" && git fetch origin)

    if [ "$target" = "main" ]; then
        echo "Pulling latest main..."
        (cd "$REPO_DIR" && git checkout main && git pull origin main)
    else
        echo "Checking out $target..."
        (cd "$REPO_DIR" && git checkout "$target")
    fi

    local commit
    commit=$(cd "$REPO_DIR" && git log --oneline -1)
    echo "Now at: $commit"

    # Update dependencies
    echo "Updating dependencies..."
    "$VENV_DIR/bin/pip" install --quiet -r "$SERVER_DIR/requirements.txt"
    _green "Dependencies updated."

    # Regenerate plist in case paths changed
    _ensure_plist

    # Restart if running
    if _is_running; then
        echo "Restarting server..."
        cmd_restart
    else
        _yellow "Server not running. Start with: swingcam start"
    fi

    _green "Update complete."
}

_is_linux() {
    [[ "$(uname -s)" == "Linux" ]]
}

_require_linux_systemd() {
    if ! _is_linux; then
        _red "stream $1 manages a systemd unit and only runs on the Pi (Linux)."
        exit 1
    fi
    if ! command -v systemctl >/dev/null 2>&1; then
        _red "systemctl not found — swing-cam stream service requires systemd."
        exit 1
    fi
}

_require_root() {
    if [ "$EUID" -ne 0 ]; then
        _red "stream $1 writes to /etc/systemd/system — re-run with sudo."
        exit 1
    fi
}

cmd_stream_start() {
    _require_linux_systemd "start"
    _require_root "start"

    if [ "$#" -eq 0 ]; then
        _red "Usage: sudo swingcam stream start <ff|dtl> <server> [port]"
        exit 1
    fi

    local angle_arg="$1"
    local server_arg="${2:-}"
    local port_arg="${3:-}"

    case "$angle_arg" in
        ff|front-facing|dtl|down-the-line) ;;
        *)
            _red "Invalid angle: '$angle_arg' (must be ff|front-facing or dtl|down-the-line)"
            exit 1
            ;;
    esac

    # Resolve server: explicit arg first, then the calling user's pi.env.
    # Under sudo, $HOME points at /root, so consult $SUDO_USER's home directly.
    local target_user="${SUDO_USER:-$(whoami)}"
    local target_home
    target_home=$(getent passwd "$target_user" 2>/dev/null | cut -d: -f6)
    target_home="${target_home:-$HOME}"
    local pi_env="$target_home/.swingcam/pi.env"

    local server_ip="$server_arg"
    if [ -z "$server_ip" ] && [ -f "$pi_env" ]; then
        # shellcheck disable=SC1090
        source "$pi_env"
        server_ip="${SWINGCAM_SERVER:-}"
    fi
    if [ -z "$server_ip" ]; then
        _red "Server IP required. Usage: sudo swingcam stream start <ff|dtl> <server> [port]"
        exit 1
    fi

    # Persist the resolved server for subsequent foreground `swingcam stream`
    # invocations by the same user (matches existing pi.env behavior).
    install -d -o "$target_user" "$target_home/.swingcam"
    printf 'SWINGCAM_SERVER=%s\n' "$server_ip" > "$pi_env"
    chown "$target_user" "$pi_env"

    local exec_line="$REPO_DIR/swingcam stream $angle_arg $server_ip"
    if [ -n "$port_arg" ]; then
        exec_line="$exec_line $port_arg"
    fi

    cat > "$SYSTEMD_UNIT_PATH" <<UNIT
[Unit]
Description=swing-cam H.264 stream ($angle_arg → $server_ip)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$exec_line
Restart=always
RestartSec=10
User=$target_user
StandardOutput=journal
StandardError=journal
SyslogIdentifier=swing-cam-stream

[Install]
WantedBy=multi-user.target
UNIT

    systemctl daemon-reload
    systemctl enable --now "$SYSTEMD_UNIT_NAME"

    _green "Stream service installed and running ($angle_arg → $server_ip)."
    echo "  Unit:    $SYSTEMD_UNIT_PATH"
    echo "  Status:  sudo systemctl status $SYSTEMD_UNIT_NAME"
    echo "  Logs:    journalctl -u $SYSTEMD_UNIT_NAME -f"
}

cmd_stream_stop() {
    _require_linux_systemd "stop"
    _require_root "stop"

    if [ ! -f "$SYSTEMD_UNIT_PATH" ]; then
        _yellow "Stream service is not installed."
        return 0
    fi
    systemctl disable --now "$SYSTEMD_UNIT_NAME" 2>/dev/null || true
    _green "Stream service stopped and disabled at boot."
    echo "  Unit file kept at $SYSTEMD_UNIT_PATH; re-enable with: sudo swingcam stream start ..."
}

cmd_stream_restart() {
    _require_linux_systemd "restart"
    _require_root "restart"

    if [ "$#" -gt 0 ]; then
        cmd_stream_start "$@"
        return
    fi
    if [ ! -f "$SYSTEMD_UNIT_PATH" ]; then
        _red "Stream service is not installed. Run: sudo swingcam stream start <ff|dtl> <server>"
        exit 1
    fi
    systemctl restart "$SYSTEMD_UNIT_NAME"
    _green "Stream service restarted."
}

cmd_stream_status() {
    _require_linux_systemd "status"

    echo "── stream service status ──"
    if [ ! -f "$SYSTEMD_UNIT_PATH" ]; then
        _red "Not installed. Install with: sudo swingcam stream start <ff|dtl> <server>"
        return 0
    fi
    systemctl status "$SYSTEMD_UNIT_NAME" --no-pager || true
}

cmd_stream_logs() {
    _require_linux_systemd "logs"
    journalctl -u "$SYSTEMD_UNIT_NAME" -f
}

cmd_stream() {
    # Parse --test flag; remaining args are positional.
    local test_mode=0
    local args=()
    for arg in "$@"; do
        case "$arg" in
            --test) test_mode=1 ;;
            *) args+=("$arg") ;;
        esac
    done

    local angle_arg="${args[0]:-}"
    local server_ip_arg="${args[1]:-}"
    local port_override="${args[2]:-}"

    local angle port
    case "$angle_arg" in
        ff|front-facing)   angle="ff";  port=9556 ;;
        dtl|down-the-line) angle="dtl"; port=9557 ;;
        "")
            _red "Usage: swingcam stream [--test] <ff|dtl> <server> [port]"
            exit 1
            ;;
        *)
            _red "Unknown angle: '$angle_arg' (must be ff|front-facing or dtl|down-the-line)"
            exit 1
            ;;
    esac

    if [ -n "$port_override" ]; then
        port="$port_override"
    fi

    # Resolve server IP: arg > env > stored file > prompt
    local pi_env="$APP_DIR/pi.env"
    local server_ip=""
    if [ -n "$server_ip_arg" ]; then
        server_ip="$server_ip_arg"
    elif [ -n "${SWINGCAM_SERVER:-}" ]; then
        server_ip="$SWINGCAM_SERVER"
    elif [ -f "$pi_env" ]; then
        # shellcheck disable=SC1090
        source "$pi_env"
        server_ip="${SWINGCAM_SERVER:-}"
    fi

    if [ -z "$server_ip" ]; then
        if [ "$test_mode" = "1" ]; then
            server_ip="localhost"
        else
            mkdir -p "$APP_DIR"
            read -rp "Server IP address: " server_ip
            if [ -z "$server_ip" ]; then
                _red "Server IP required."
                exit 1
            fi
            printf 'SWINGCAM_SERVER=%s\n' "$server_ip" > "$pi_env"
            _green "Saved server IP to $pi_env"
        fi
    fi

    # Test mode: skip rpicam-vid, run the Python synthetic stream instead
    if [ "$test_mode" = "1" ]; then
        _ensure_venv
        echo "Test mode: synthetic stream (still → swing burst → still)"
        exec "$VENV_DIR/bin/python" "$SERVER_DIR/test_stream.py" "$server_ip" "$port"
    fi

    if ! command -v rpicam-vid &>/dev/null; then
        if ! command -v apt-get &>/dev/null; then
            _red "rpicam-vid not found — this command must run on a Raspberry Pi."
            exit 1
        fi
        echo "rpicam-vid not found. Installing rpicam-apps..."
        sudo apt-get update
        sudo apt-get install -y rpicam-apps
        if ! command -v rpicam-vid &>/dev/null; then
            _red "Install completed but rpicam-vid still not found. Aborting."
            exit 1
        fi
        _green "rpicam-apps installed."
    fi

    # rpicam-vid won't accept hostnames in tcp://… URLs, only literal IPs.
    # Resolve via NSS (mDNS-enabled on Pi OS) before passing it through.
    if [[ ! "$server_ip" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        local resolved
        resolved=$(getent ahosts "$server_ip" 2>/dev/null | awk '/STREAM/ {print $1; exit}')
        if [ -z "$resolved" ]; then
            resolved=$(getent hosts "$server_ip" 2>/dev/null | awk '{print $1; exit}')
        fi
        if [ -z "$resolved" ]; then
            _red "Could not resolve '$server_ip'. Pass an IP address directly, or check your DNS/mDNS setup."
            exit 1
        fi
        echo "  Resolved ${server_ip} → ${resolved}"
        server_ip="$resolved"
    fi

    # Stream parameters — keep in sync with server stream config
    local WIDTH=1280
    local HEIGHT=720
    local FRAMERATE=30          # 30 for Pi Zero W, 60 for Pi Zero 2 W
    local BITRATE=8000000       # 8 Mbps
    local INTRA_FRAMES=$FRAMERATE  # keyframe every ~1s (frame count, not ms)
    local MAX_GAIN=4               # cap analog gain to limit noise (default ~16)
    local AUDIO_PORT=9558          # shared audio port on the server
    local AUDIO_RATE=16000         # mono PCM @ 16kHz, plenty for impact detection

    echo "swing-cam streamer ($angle)"
    echo "  Resolution:  ${WIDTH}x${HEIGHT} @ ${FRAMERATE}fps"
    echo "  Bitrate:     $((BITRATE / 1000)) kbps"
    echo "  Streaming to: ${server_ip}:${port}"

    # Audio: only spin up if a USB capture device is plugged in. Both Pis
    # run this loop unconditionally; only one connects to the server's
    # single-client listener at a time. The other gets ECONNREFUSED and
    # retries, which is the desired "either Pi can host the mic" behavior.
    local mic_card=""
    if command -v arecord &>/dev/null; then
        # Pick the first capture card whose driver isn't the onboard bcm2835.
        mic_card=$(arecord -l 2>/dev/null \
            | awk '/^card [0-9]+:/ && !/bcm2835/ {gsub(":", "", $2); print $2; exit}')
    fi

    local audio_pid=""
    if [ -n "$mic_card" ] && command -v ffmpeg &>/dev/null; then
        echo "  Audio:       USB mic on card ${mic_card} → tcp://${server_ip}:${AUDIO_PORT}"
        (
            while true; do
                ffmpeg -hide_banner -loglevel error \
                    -f alsa -ac 1 -ar "$AUDIO_RATE" -i "plughw:${mic_card},0" \
                    -f s16le "tcp://${server_ip}:${AUDIO_PORT}" 2>&1 \
                    | sed 's/^/[audio] /' || true
                echo "[audio] Disconnected (server full or down). Retrying in 10s..."
                sleep 10
            done
        ) &
        audio_pid=$!
    elif [ -n "$mic_card" ]; then
        echo "  Audio:       USB mic detected but ffmpeg missing — skipping"
    else
        echo "  Audio:       no USB microphone detected"
    fi

    # Ctrl+C exits cleanly instead of looping into the next retry. Also kills
    # the audio child so it doesn't keep retrying after the parent is gone.
    trap '
        echo
        if [ -n "${audio_pid:-}" ]; then
            kill "$audio_pid" 2>/dev/null || true
        fi
        echo "Stream stopped."
        exit 0
    ' INT TERM

    # Quiet libcamera's INFO chatter; warnings/errors still surface.
    export LIBCAMERA_LOG_LEVELS='*:WARN'

    # Retry loop — if the server isn't up yet, keep trying
    while true; do
        echo "Connecting to ${server_ip}:${port}..."
        rpicam-vid \
            --verbose 0 \
            -t 0 \
            --width "$WIDTH" \
            --height "$HEIGHT" \
            --framerate "$FRAMERATE" \
            --bitrate "$BITRATE" \
            --codec h264 \
            --profile high \
            --level 4.1 \
            --inline \
            --flush \
            --intra "$INTRA_FRAMES" \
            --gain "$MAX_GAIN" \
            --denoise cdn_hq \
            -o "tcp://${server_ip}:${port}" || true

        echo "Stream ended. Retrying in 5s..."
        sleep 5
    done
}

cmd_help() {
    cat <<HELP
swingcam — manage the swing-cam server daemon

Commands:
  start           Start the server daemon
  stop            Stop the server daemon
  restart         Restart the server daemon
  status          Show daemon status, paths, storage, and recent logs
  logs            Tail the server logs (Ctrl+C to stop)
  config          Edit the config file (restarts server if running)
  update [SHA]    Pull latest main (or checkout a specific SHA) and restart

Streaming commands:
  stream <ff|dtl> <server> [port]
                  Stream the Pi camera to the server (foreground).
                  Angle selects port:
                    ff  → 9556 (front-facing)
                    dtl → 9557 (down-the-line)
                    Server is a hostname or IP (e.g. "swingcam" or "192.168.4.234").
                    Port defaults based on angle but can be overridden.

  stream start <ff|dtl> <server> [port]   (Pi only, requires sudo)
                  Install a systemd unit that streams to the server, runs
                  on every boot, and auto-restarts on failure. Logs go to
                  the systemd journal. Re-run to update the angle/server.

  stream stop     (Pi, sudo) Stop and disable the stream service.
  stream restart  (Pi, sudo) Restart the stream service. With args, re-installs.
  stream status   (Pi)       systemctl status of the stream service.
  stream logs     (Pi)       Tail the journal for the stream service.

  stream --test <ff|dtl> [server] [port]
                  Send a synthetic test stream that simulates a swing
                  pattern (still → motion burst → still). Useful for
                  verifying detection without a real camera.
                  Server defaults to localhost.

Data directory: $APP_DIR
  config.yaml     Server configuration
  clips/          Saved swing clips
  swings.db       Swing database
  logs/           Rotated log files
  models/         MediaPipe model files (auto-downloaded)

First-time setup:
  swingcam start
HELP
}

# ── Main ──

case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    config)  cmd_config ;;
    update)  cmd_update "${2:-main}" ;;
    stream)
        shift
        case "${1:-}" in
            start)   shift; cmd_stream_start "$@" ;;
            stop)    cmd_stream_stop ;;
            restart) shift; cmd_stream_restart "$@" ;;
            status)  cmd_stream_status ;;
            logs)    cmd_stream_logs ;;
            *)       cmd_stream "$@" ;;
        esac
        ;;
    help|--help|-h) cmd_help ;;
    *)
        _red "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
